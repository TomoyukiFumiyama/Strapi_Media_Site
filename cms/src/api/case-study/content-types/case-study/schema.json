{
  "kind": "collectionType",
  "collectionName": "case_studys",
  "info": {
    "singularName": "case-study",
    "pluralName": "case-studys",
    "displayName": "case-study"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "summary": {
      "type": "text"
    },
    "cover_image": {
      "type": "media",
      "allowedTypes": [
        "images"
      ],
      "multiple": false
    },
    "problem": {
      "type": "richtext"
    },
    "solution": {
      "type": "richtext"
    },
    "result_summary": {
      "type": "richtext"
    },
    "metrics": {
      "type": "component",
      "repeatable": true,
      "component": "shared.kpi-stat"
    },
    "testimonial": {
      "type": "component",
      "component": "shared.testimonial"
    },
    "gallery": {
      "type": "media",
      "allowedTypes": [
        "images"
      ],
      "multiple": true
    },
    "related_services": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::service.service"
    },
    "related_areas": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::area.area"
    },
    "featured_download": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::lead-magnet.lead-magnet"
    },
    "content_blocks": {
      "type": "dynamiczone",
      "components": [
        "blocks.rich-text",
        "blocks.image-text",
        "blocks.quote",
        "blocks.faq-section",
        "blocks.cta-banner",
        "blocks.stats-section",
        "blocks.related-posts",
        "blocks.related-case-studies",
        "blocks.download-cta",
        "blocks.office-info"
      ]
    },
    "seo": {
      "type": "component",
      "component": "shared.seo"
    },
    "is_featured": {
      "type": "boolean",
      "default": false
    }
  }
}