{
  "kind": "collectionType",
  "collectionName": "local_pages",
  "info": {
    "singularName": "local-page",
    "pluralName": "local-pages",
    "displayName": "local-page"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "area": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::area.area"
    },
    "service": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::service.service"
    },
    "hero": {
      "type": "component",
      "component": "shared.hero"
    },
    "local_intro": {
      "type": "richtext"
    },
    "local_problem_points": {
      "type": "component",
      "repeatable": true,
      "component": "shared.point-item"
    },
    "local_strengths": {
      "type": "component",
      "repeatable": true,
      "component": "shared.point-item"
    },
    "local_faq": {
      "type": "component",
      "repeatable": true,
      "component": "shared.faq-item"
    },
    "nearby_office": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::office.office"
    },
    "related_case_studies": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::case-study.case-study"
    },
    "featured_download": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::lead-magnet.lead-magnet"
    },
    "content_blocks": {
      "type": "dynamiczone",
      "components": [
        "blocks.rich-text",
        "blocks.image-text",
        "blocks.quote",
        "blocks.faq-section",
        "blocks.cta-banner",
        "blocks.stats-section",
        "blocks.related-posts",
        "blocks.related-case-studies",
        "blocks.download-cta",
        "blocks.office-info"
      ]
    },
    "seo": {
      "type": "component",
      "component": "shared.seo"
    },
    "canonical_url": {
      "type": "string"
    },
    "noindex": {
      "type": "boolean",
      "default": false
    },
    "is_featured": {
      "type": "boolean",
      "default": false
    }
  }
}